<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="StaticList" Id="{b00cea89-06fa-4e30-933a-d0c01bdd7424}" SpecialFunc="None">
    <Declaration><![CDATA[(*

.. <legal notes>

