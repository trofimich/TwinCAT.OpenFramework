<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="StaticListEnumerator" Id="{99c6276a-5a2a-4b7f-9773-23643848a452}" SpecialFunc="None">
    <Declaration><![CDATA[(*

.. <legal notes>

