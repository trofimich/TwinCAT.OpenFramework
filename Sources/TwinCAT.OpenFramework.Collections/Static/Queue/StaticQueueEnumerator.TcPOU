<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="StaticQueueEnumerator" Id="{76621809-c2cb-40a2-85ac-89e64bec6bfb}" SpecialFunc="None">
    <Declaration><![CDATA[(*

.. <legal notes>

