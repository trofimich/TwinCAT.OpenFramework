{attribute 'no_explicit_call' := 'do not call this function block directly'} 
FUNCTION_BLOCK List 
VAR_GENERIC CONSTANT
    _StaticCapacity : COLLECTION_LENGTH := 0;
END_VAR
EXTENDS Core.Object IMPLEMENTS IList
VAR_INPUT
	DefaultDynamicAllocationElemetCount : BYTE := 10;	
END_VAR
VAR
	_ClassName : STRING := __POUNAME();

	_ValueValidator : Core.IGenericValueValidator;

	_Array : POINTER TO Core.GENERIC_VALUE;
	_StaticArray : ARRAY [0.._StaticCapacity - 1] OF Core.GENERIC_VALUE;
	
	_DynamicCapacity : COLLECTION_LENGTH;
	_Length : DINT;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="AllocateMemory" Id="{7805ad4a-1088-4228-99dd-d8b7fe4579c3}">
      <Declaration><![CDATA[METHOD PROTECTED AllocateMemory 
VAR_INPUT
	elementCount : COLLECTION_LENGTH;
END_VAR
VAR	
	newMemory : POINTER TO GENERIC_VALUE;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT Dynamic THEN
	RETURN;
END_IF

newMemory := __NEW(BYTE, TO_UDINT(SIZEOF(GENERIC_VALUE) * (_DynamicCapacity + elementCount)));

IF _Length > 0 THEN
	Tc2_System.MEMCPY(newMemory, _Array, TO_UDINT(SIZEOF(GENERIC_VALUE) * _Length));
END_IF
 
IF _Array <> 0 THEN
	__DELETE(_Array);
END_IF

_DynamicCapacity := _DynamicCapacity + elementCount;

_Array := newMemory;]]></ST>
      </Implementation>
    </Method>
    <Method Name="AppendCopy" Id="{c48f84f5-3206-4f8e-a06b-95fdd5877efa}">
      <Declaration><![CDATA[METHOD AppendCopy : IList
VAR_INPUT
	value : ANY;
	isObject : BOOL := FALSE;
END_VAR
VAR_OUTPUT
	index : COLLECTION_INDEX;
END_VAR
VAR
	genericValue : Core.GENERIC_VALUE;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[genericValue := GenericValueFactory.FromAnyType(value, isObject, GENERIC_MEMORY_MANAGEMENT_BEHAVIOR.CLONE_ORIGINAL_VALUE_AND_OWNS_MEMORY);

__TRY
	AppendCopy := AppendGeneric(genericValue, index => index);
__CATCH
	genericValue.Release();
	
	Core.ExceptionManager.ReThrowLastException();	
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="AppendGeneric" Id="{f1ff6a71-50a0-45d9-ae86-164a44b67bf8}">
      <Declaration><![CDATA[METHOD AppendGeneric : IList
VAR_INPUT
	value : GENERIC_VALUE;
END_VAR
VAR_OUTPUT
	index : COLLECTION_INDEX;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[index := _Length;

AppendGeneric := InsertGeneric(index, value);]]></ST>
      </Implementation>
    </Method>
    <Property Name="Capacity" Id="{f88ebbc6-043e-4384-9aab-efeb366abd1b}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL Capacity : COLLECTION_LENGTH]]></Declaration>
      <Get Name="Get" Id="{e0e73894-ad23-446a-99c0-aacf7f854d6b}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Capacity := SEL(_StaticCapacity = 0, _StaticCapacity, _DynamicCapacity);]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="ClassName" Id="{33e07dae-fed5-4e1d-8f43-eee6214a3816}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY ClassName : STRING]]></Declaration>
      <Get Name="Get" Id="{f6501ffd-91a8-433d-945c-613d26b30c47}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[ClassName := _ClassName;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="Clear" Id="{6eeb2dd8-b2fb-4bd3-af28-3d4655f329b4}">
      <Declaration><![CDATA[METHOD Clear : IList
VAR
	i : DINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[Clear := THIS^;

FOR i := 0 TO _Length - 1 DO
	_Array[i].Release();						
END_FOR	

_Length := 0;
_DynamicCapacity := 0;

IF _Array <> 0 AND_THEN Dynamic THEN
	__DELETE(_Array);	
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="CreateEnumerator" Id="{9c229dd9-393b-46ff-976f-739fe26eedc5}">
      <Declaration><![CDATA[METHOD CreateEnumerator : IEnumerator
VAR
	enumerator : POINTER TO ListEnumerator;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[enumerator := __NEW(ListEnumerator(list := THIS^));

CreateEnumerator := enumerator^;]]></ST>
      </Implementation>
    </Method>
    <Property Name="Dynamic" Id="{166b951e-511c-4d32-bb47-240a0b602e17}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL Dynamic : BOOL]]></Declaration>
      <Get Name="Get" Id="{629e79ca-4190-4ac7-928c-69e20f8bf579}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Dynamic := _StaticCapacity = 0;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="Empty" Id="{6c336543-2ac9-4adb-b317-6015c15c963c}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL Empty : BOOL]]></Declaration>
      <Get Name="Get" Id="{cbbea261-31d9-4fda-a46a-9b7d9838e2ea}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Empty := _Length <= 0;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="FB_exit" Id="{8d8b7b19-3218-490a-a08e-e708f6895db1}">
      <Declaration><![CDATA[METHOD FB_exit : BOOL
VAR_INPUT
	bInCopyCode : BOOL; // if TRUE, the exit method is called for exiting an instance that is copied afterwards (online change).
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[Clear();]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{7bc30a89-0227-48d6-bfc1-e831cfff4350}">
      <Declaration><![CDATA[METHOD FB_init : BOOL
VAR_INPUT
	(* if TRUE, the retain variables are initialized (warm start / cold start)*)
	bInitRetains	: BOOL;
	(* if TRUE, the instance afterwards gets moved into the copy code (online change)*)
	bInCopyCode	: BOOL;
	valueValidator : IGenericValueValidator;
END_VAR
]]></Declaration>
      <Implementation>
        <ST><![CDATA[_ValueValidator := valueValidator;

IF NOT Dynamic THEN
	_Array := ADR(_StaticArray); 
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="FindSingle" Id="{5bd8df97-f8f3-46ed-97e0-2baa71205501}">
      <Declaration><![CDATA[METHOD FindSingle : BOOL
VAR_INPUT
	predicate : IPredicate;
	skip : UDINT := 0;
	searchDirection : SEARCH_DIRECTION := SEARCH_DIRECTION.FROM_BEGINNING;
END_VAR
VAR_OUTPUT
	value : GENERIC_VALUE;
	index : COLLECTION_INDEX;
END_VAR
VAR
	startSearchIndex : DINT;
	maxSearchIndex : DINT;
	indexStep : DINT;
	
	i : DINT;
	
	currentValue : __SYSTEM.AnyType;

	skiped : UDINT := 0;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[index := 0;
	
IF TO_DINT(skip) >= _Length OR_ELSE predicate = 0 THEN
	RETURN;
END_IF

startSearchIndex := SEL(searchDirection = SEARCH_DIRECTION.FROM_BEGINNING, _Length - 1, 0);
maxSearchIndex := SEL(searchDirection = SEARCH_DIRECTION.FROM_BEGINNING, 0, _Length - 1);
indexStep := SEL(searchDirection = SEARCH_DIRECTION.FROM_BEGINNING, -1, 1);

FOR i := startSearchIndex TO maxSearchIndex BY indexStep DO
	currentValue := _Array[i].AsAnyType();
	
	IF predicate.Check(currentValue) THEN
		IF skip = skiped THEN
			value := _Array[i];
			index := i;
			FindSingle := TRUE;
			RETURN;
		ELSE
			skiped := skiped + 1;
		END_IF
	END_IF
END_FOR]]></ST>
      </Implementation>
    </Method>
    <Property Name="Full" Id="{142088f9-89b6-4514-9bf8-182d44bd5096}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL Full : BOOL]]></Declaration>
      <Get Name="Get" Id="{60f38d2d-7d5e-4f53-bd6e-39eabf1a5689}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Full := _StaticCapacity <> 0 AND_THEN _Length >= _StaticCapacity;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="Get" Id="{35156606-e33f-4fd7-a3f8-50e4c6feea06}">
      <Declaration><![CDATA[METHOD Get : REFERENCE TO Core.GENERIC_VALUE
VAR_INPUT
	index : COLLECTION_INDEX;
END_VAR
VAR
	argumentOutOfRangeException : ArgumentOutOfRangeException;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF index < 0 OR_ELSE index >= _Length THEN
	argumentOutOfRangeException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), 'index', index);
END_IF

Get REF= _Array[index];]]></ST>
      </Implementation>
    </Method>
    <Method Name="InsertCopy" Id="{7c5e7ea9-1602-45c2-9555-47aa08559820}">
      <Declaration><![CDATA[METHOD InsertCopy : IList
VAR_INPUT
	index : COLLECTION_INDEX;
	value : ANY;
	isObject : BOOL := FALSE;
END_VAR
VAR
	genericValue : Core.GENERIC_VALUE;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[genericValue := GenericValueFactory.FromAnyType(value, isObject, GENERIC_MEMORY_MANAGEMENT_BEHAVIOR.CLONE_ORIGINAL_VALUE_AND_OWNS_MEMORY);

__TRY
	InsertCopy := InsertGeneric(index, genericValue);
__CATCH
	genericValue.Release();
	
	Core.ExceptionManager.ReThrowLastException();
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="InsertGeneric" Id="{2dcf43ab-5d4d-40f0-ba4f-54f191c32509}">
      <Declaration><![CDATA[METHOD InsertGeneric : IList
VAR_INPUT
	index : COLLECTION_INDEX;
	value : GENERIC_VALUE;	
END_VAR
VAR
	argumentOutOfRangeException : ArgumentOutOfRangeException;
	staticCollectionFullException : Core.StaticCollectionFullException;
	
	i : DINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF index < 0 OR_ELSE index > _Length THEN
	argumentOutOfRangeException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), 'index', index);
END_IF

IF _ValueValidator <> 0 THEN
	_ValueValidator.Validate(GetName(), value);
END_IF

InsertGeneric := THIS^;

IF _Length >= Capacity THEN
	IF Dynamic THEN
		AllocateMemory(DefaultDynamicAllocationElemetCount);
	ELSE
		staticCollectionFullException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), GetName(), TO_UDINT(Capacity));
	END_IF
END_IF

_Length := _Length + 1;

i := _Length - 1;

WHILE i > index DO
	_Array[i] := _Array[i - 1];	
	i := i - 1;
END_WHILE

_Array[i] := value;]]></ST>
      </Implementation>
    </Method>
    <Property Name="Length" Id="{8b78c4a9-2b51-4df9-a89b-35d75f4063d7}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL Length : COLLECTION_LENGTH]]></Declaration>
      <Get Name="Get" Id="{40434b4f-ac59-4ed2-adb0-38a6ead17ebd}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Length := _Length;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="NamespaceName" Id="{790d2c44-7c10-4ff7-8e9f-92d4936a4655}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY NamespaceName : STRING]]></Declaration>
      <Get Name="Get" Id="{dfd8ff83-c535-4eea-abbd-5a05ac36fe99}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[NamespaceName := CurrentNamespace.Name;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="RemoveAt" Id="{0e28301b-e63b-49ca-a697-ef9528fc2481}">
      <Declaration><![CDATA[METHOD RemoveAt : IList
VAR_INPUT
	index : COLLECTION_INDEX;
END_VAR
VAR
	argumentOutOfRangeException : Core.ArgumentOutOfRangeException;

	i : DINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF index < 0 OR_ELSE index >= _Length THEN
	argumentOutOfRangeException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), 'index', index);
END_IF

RemoveAt := THIS^;

_Array[index].Release();			

IF index < _Length - 1 THEN
	Tc2_System.MEMMOVE(ADR(_Array[index]), ADR(_Array[index + 1]), TO_UDINT(SIZEOF(Core.GENERIC_VALUE) * (_Length - index - 1)));
END_IF

(*FOR	i := index TO _Length - 2 DO
	_Array[i] := _Array[i + 1];
END_FOR*)			

_Array[_Length - 1].Reset();	

_Length := _Length - 1;]]></ST>
      </Implementation>
    </Method>
    <Method Name="RemoveFirst" Id="{ab28382f-e74f-44a6-bee2-f905f3030356}">
      <Declaration><![CDATA[METHOD RemoveFirst : IList
VAR_INPUT
	value : ANY;
	isObject : BOOL := FALSE;
END_VAR
VAR_OUTPUT
	removed : BOOL;
END_VAR
VAR
	i : DINT;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[RemoveFirst := THIS^;

IF _Length > 0 THEN
	FOR i := 0 TO _Length - 1 DO
		IF _Array[i].Equals(GenericValueFactory.FromAnyType(value, isObject, GENERIC_MEMORY_MANAGEMENT_BEHAVIOR.STORE_ORIGINAL_REFERENCE_AND_NOT_OWNS_MEMORY)) THEN
			RemoveAt(i);
			removed := TRUE;
			RETURN;
		END_IF
	END_FOR
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="RemoveMatched" Id="{e5cc38ae-8b20-4e35-acc9-fcd84e9d10bd}">
      <Declaration><![CDATA[METHOD RemoveMatched : IList
VAR_INPUT
	predicate : IPredicate;
	skip : UDINT := 0;
	maxRemoved : UDINT := 16#FFFFFFFF;
END_VAR
VAR_OUTPUT
	removedCount : DINT;
END_VAR
VAR
	i : DINT;

	currentValue : __SYSTEM.AnyType;

	skiped : UDINT := 0;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[RemoveMatched := THIS^;

IF TO_DINT(skip) >= _Length OR_ELSE predicate = 0 OR_ELSE maxRemoved = 0 THEN
	RETURN;
END_IF

FOR i := _Length - 1 TO 0 BY -1 DO
	currentValue := _Array[i].AsAnyType();
	
	IF predicate.Check(currentValue) THEN
		IF skip <= skiped THEN
			RemoveAt(i);
			removedCount := removedCount + 1;
		ELSE
			skiped := skiped + 1;
		END_IF
	END_IF
END_FOR]]></ST>
      </Implementation>
    </Method>
    <Property Name="SelfSize" Id="{b8f1c23e-6bde-4d17-b77f-f3d1373a6f6b}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY SelfSize : ULINT]]></Declaration>
      <Get Name="Get" Id="{0c60dbce-56ff-4644-ae28-c3c705772b31}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[SelfSize := XSIZEOF(THIS^);]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="SetCopy" Id="{e9638d43-e88c-48cb-a07f-937c5e87c232}">
      <Declaration><![CDATA[METHOD SetCopy : IList
VAR_INPUT
	index : COLLECTION_INDEX;
	value : ANY;
	isObject : BOOL := FALSE;
END_VAR
VAR
	genericValue : Core.GENERIC_VALUE;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[genericValue := GenericValueFactory.FromAnyType(value, isObject, GENERIC_MEMORY_MANAGEMENT_BEHAVIOR.CLONE_ORIGINAL_VALUE_AND_OWNS_MEMORY);

__TRY
	SetCopy := SetGeneric(index, genericValue);
__CATCH
	genericValue.Release();
	
	Core.ExceptionManager.ReThrowLastException();
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetGeneric" Id="{28fb4746-7d53-4b08-a432-54d437f989bb}">
      <Declaration><![CDATA[METHOD SetGeneric : IList
VAR_INPUT
	index : COLLECTION_INDEX;
	value : GENERIC_VALUE;	
END_VAR
VAR
	argumentOutOfRangeException : Core.ArgumentOutOfRangeException;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF index < 0 OR_ELSE index >= _Length THEN
	argumentOutOfRangeException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), 'index', index);
END_IF

IF _ValueValidator <> 0 THEN
	_ValueValidator.Validate(GetName(), value);
END_IF

SetGeneric := THIS^;

IF _Array[index].TypeClass <> value.TypeClass OR_ELSE _Array[index].Address <> value.Address OR_ELSE _Array[index].Size <> value.Size OR_ELSE _Array[index].IsMemoryOwner <> value.IsMemoryOwner THEN
	_Array[index].Release();	
	_Array[index] := value;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="Sort" Id="{cd2a8a15-72bb-44f7-9e5d-ecb76fed56a8}">
      <Declaration><![CDATA[METHOD Sort : IReadOnlyList
VAR_INPUT
	comparer : IComparer;
	direction : SORT_DIRECTION := SORT_DIRECTION.ASCENDING;
END_VAR
VAR
	argumentNullException : ArgumentNotSpecifiedException;
	
	replaced : BOOL;
	
	i : DINT;
	
	comparisionResult : COMPARISION_RESULT;
	
	value1, value2 : __SYSTEM.AnyType;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF comparer = 0 THEN
	argumentNullException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), 'comparer');
END_IF

Sort := THIS^;

// todo: implement more effective sorting
REPEAT
	replaced := FALSE;
	
	IF _Length > 1 THEN
		FOR i := 0 TO _Length - 2 DO
			value1 := _Array[i].AsAnyType();
			value2 := _Array[i + 1].AsAnyType();
			
			comparisionResult := comparer.Compare(value1, value2);
			
			IF direction = SORT_DIRECTION.ASCENDING THEN
				IF comparisionResult = COMPARISION_RESULT.FIRST_GREATER_THAN_SECOND THEN
					Swap(i, i + 1);
					replaced := TRUE;
				END_IF
			ELSE
				IF comparisionResult = COMPARISION_RESULT.FIRST_LESS_THAN_SECOND THEN
					Swap(i, i + 1);
					replaced := TRUE;
				END_IF			
			END_IF
		END_FOR		
	END_IF
UNTIL
	NOT replaced
END_REPEAT

]]></ST>
      </Implementation>
    </Method>
    <Method Name="Swap" Id="{eb0e8297-edd7-472f-a573-82e2ae740339}">
      <Declaration><![CDATA[METHOD Swap : IReadOnlyList
VAR_INPUT
	index1 : COLLECTION_INDEX;
	index2 : COLLECTION_INDEX;
END_VAR
VAR
	argumentOutOfRangeException : ArgumentOutOfRangeException;
	tmp : GENERIC_VALUE;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[Swap := THIS^;

IF index1 = index2 THEN
	RETURN;
ELSIF index1 < 0 OR_ELSE index1 >= _Length THEN
	argumentOutOfRangeException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), 'index1', index1);
ELSIF index2 < 0 OR_ELSE index2 >= _Length THEN
	argumentOutOfRangeException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), 'index2', index2);
END_IF

tmp := _Array[index1];
_Array[index1] := _Array[index2];
_Array[index2] := tmp;]]></ST>
      </Implementation>
    </Method>
    <Property Name="ValueValidator" Id="{b948083e-197f-42c4-870d-0ac963bd346a}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL ValueValidator : Core.IGenericValueValidator]]></Declaration>
      <Get Name="Get" Id="{cb2fa504-489a-4e73-8b3c-20c2650b6edd}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[ValueValidator := _ValueValidator;]]></ST>
        </Implementation>
      </Get>
    </Property>
  </POU>
</TcPlcObject>