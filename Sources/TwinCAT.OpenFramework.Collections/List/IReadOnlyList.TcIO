    <Method Name="FindSingle" Id="{1b102e63-f5bc-45b5-87cf-c33b4c4088e7}">
      <Declaration><![CDATA[METHOD FindSingle : BOOL
VAR_INPUT
	predicate : IPredicate;
	skip : UDINT := 0;
	searchDirection : SEARCH_DIRECTION := SEARCH_DIRECTION.FROM_BEGINNING;
END_VAR
VAR_OUTPUT
	value : GENERIC_VALUE;
	index : COLLECTION_INDEX;
END_VAR]]></Declaration>
    </Method>
    <Property Name="Full" Id="{9fe15f64-e9c9-43cf-ae85-2cbc0b5e3106}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL Full : BOOL]]></Declaration>
      <Get Name="Get" Id="{f2c42cc1-f16e-4a3d-b820-e4d406744411}">
        <Declaration><![CDATA[]]></Declaration>
