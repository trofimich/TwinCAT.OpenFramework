    <Method Name="Get" Id="{f5cd9212-1ade-4b6f-92a1-97d3e216a850}">
      <Declaration><![CDATA[METHOD Get : REFERENCE TO Core.GENERIC_VALUE
VAR_INPUT
	index : COLLECTION_INDEX;
END_VAR]]></Declaration>
    </Method>
    <Method Name="Sort" Id="{b7150648-9792-4f04-bca7-75d5754e5e7c}">
      <Declaration><![CDATA[METHOD Sort : IReadOnlyList
VAR_INPUT
	comparer : IComparer;
	direction : SORT_DIRECTION := SORT_DIRECTION.ASCENDING;
END_VAR]]></Declaration>
    </Method>
    <Method Name="Swap" Id="{09e0afcd-004e-4129-b911-deb30ed5603c}">
      <Declaration><![CDATA[METHOD Swap : IReadOnlyList
