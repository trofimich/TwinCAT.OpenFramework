      </Implementation>
    </Method>
    <Method Name="OnAfterProcessOutput" Id="{29f5e80e-fe53-4517-83a9-51e51fcf63b0}" FolderPath="Methods to override\ProcessOutput\">
      <Declaration><![CDATA[METHOD PROTECTED OnAfterProcessOutput]]></Declaration>
      <Implementation>
        <ST><![CDATA[]]></ST>
      </Implementation>
    </Method>
    <Method Name="OnBeforeChildrenInitializing" Id="{96a6f588-939f-4fde-a4b8-d8f2002a7ef4}" FolderPath="Overriden members\">
      <Declaration><![CDATA[METHOD PROTECTED OnBeforeChildrenInitializing
VAR
	devicesNotSpecifiedException : Core.DataMemberNotSpecifiedException;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF _ChildCount > 0 AND_THEN NOT __ISVALIDREF(Children) THEN
	devicesNotSpecifiedException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), 'Children');
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="OnBeforeExecute" Id="{ce282655-acf4-4ac1-8632-e5d04ecfe5cd}" FolderPath="Overriden members\">
      <Declaration><![CDATA[METHOD PROTECTED FINAL OnBeforeExecute
VAR
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;	
	severity : Core.ERROR_SEVERITY;

	i : Core.INT_INDEX;

	child : IChildAutomationComponent;
	
	inputDevice : IInputDevice;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[__TRY
	OnBeforeProcessInput();
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, 'OnBeforeProcessInput');

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.FAULTED, "OnBeforeProcessInput error");		
	END_IF
__ENDTRY

FOR i := 0 TO ChildCount - 1 DO
	child := InternalTryGetChildByIndex(i);

	IF NOT child.Enabled OR_ELSE NOT __QUERYINTERFACE(child, inputDevice) THEN
		CONTINUE;
	END_IF

	inputDevice.ProcessInput(); 
	
	IF inputDevice.HasError THEN
		SetError(inputDevice.Error);

		IF _OperationalState <> OPERATIONAL_STATE.INVALID AND_THEN inputDevice.Error.Severity = Core.ERROR_SEVERITY.CRITICAL THEN
			SetState(OPERATIONAL_STATE.INVALID, "Child ProcessInput error");				
		END_IF								
	END_IF
END_FOR

__TRY
	OnAfterProcessInput();
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, 'OnAfterProcessInput');

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.FAULTED, "OnAfterProcessInput error");		
	END_IF
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="OnBeforeProcessInput" Id="{4ab63055-03bc-4ba6-8fad-908e7383de34}" FolderPath="Methods to override\ProcessInput\">
      <Declaration><![CDATA[METHOD PROTECTED OnBeforeProcessInput]]></Declaration>
      <Implementation>
