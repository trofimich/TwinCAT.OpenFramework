    <Method Name="TryGetChildByIndex" Id="{41e536e8-bb48-46c8-b4d8-f8835e391a1a}">
      <Declaration><![CDATA[METHOD FINAL TryGetChildByIndex : IChildAutomationComponent
VAR_INPUT
	index : Core.INT_INDEX;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[TryGetChildByIndex := InternalTryGetChildByIndex(index);]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>