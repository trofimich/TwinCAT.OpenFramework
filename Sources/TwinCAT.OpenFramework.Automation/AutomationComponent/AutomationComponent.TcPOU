    <Method Name="Reset" Id="{d9e3b1b6-5f1c-4e0c-b7fb-2f75b7f46fbb}">
      <Declaration><![CDATA[METHOD FINAL Reset
VAR
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;	
	severity : Core.ERROR_SEVERITY;
	
	i : Core.INT_INDEX;
		
	child : IChildAutomationComponent;	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT Enabled OR_ELSE _OperationalState <> OPERATIONAL_STATE.STOPPED THEN
	RETURN;
END_IF

_Error.Clear();

__TRY
	OnBeforeChildrenReset();
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := OnGetExceptionSeverity(exception, AUTOMATION_COMPONENT_EXCEPTION_CATCH_POINT.ON_BEFORE_CHILDREN_RESET);

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.STOPPED, "OnBeforeChildrenReset error");		
		RETURN;
	END_IF
__ENDTRY

FOR i := 0 TO InternalChildCount - 1 DO
	child := InternalTryGetChildByIndex(i);
	
	IF child.Enabled AND_THEN child.OperationalState = OPERATIONAL_STATE.WORKING AND_THEN child.HasError THEN
		child.Reset();
		
		IF child.HasError AND_THEN child.Error.Severity = Core.ERROR_SEVERITY.CRITICAL THEN
			SetError(child.Error);
			SetState(OPERATIONAL_STATE.STOPPED, "Child Reset error");		
			RETURN;
		END_IF
	END_IF
END_FOR

__TRY
	OnAfterChildrenReset();
	
	SetState(OPERATIONAL_STATE.WORKING, "Reset");
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := OnGetExceptionSeverity(exception, AUTOMATION_COMPONENT_EXCEPTION_CATCH_POINT.ON_AFTER_CHILDREN_RESET);

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.STOPPED, "OnAfterChildrenReset error");
		RETURN;		
	END_IF
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetError" Id="{db1622c3-17d5-4c3e-9fc6-44f5ab658994}" FolderPath="Service methods\">
      <Declaration><![CDATA[METHOD PROTECTED SetError
VAR_IN_OUT CONSTANT
	error : Core.ERROR;  
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT __ISVALIDREF(error) OR_ELSE error.Empty THEN
	RETURN;
END_IF

// error set when exception occured in the child, so it should not be logged 

IF _Error.Empty OR_ELSE _Error.Severity < error.Severity THEN
	_Error := error;
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetException" Id="{c8063572-3da9-4eb4-bd36-833c249f0127}" FolderPath="Service methods\">
      <Declaration><![CDATA[METHOD PROTECTED SetException
VAR_IN_OUT CONSTANT
	exception : Core.IException;  
END_VAR
VAR_INPUT
	severity : Core.ERROR_SEVERITY;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT __ISVALIDREF(exception) OR_ELSE exception.Empty THEN
	RETURN;
END_IF

// SetException called in place of first errror occurance, so it should be always logged 
Core.LogManager.TryLogException(exception, severity);

IF _Error.Empty OR_ELSE _Error.Severity < severity THEN
	exception.ToError(_Error, severity);
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="SetState" Id="{7e5ac7e2-185d-4ec3-b6e7-9e31ed957150}" FolderPath="Service methods\">
      <Declaration><![CDATA[METHOD PROTECTED SetState
VAR_INPUT
	state : OPERATIONAL_STATE;
	reason : WSTRING(255);
END_VAR
VAR
	previousState : OPERATIONAL_STATE;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_OperationalStateReason := reason;

IF _OperationalState = state THEN
	RETURN;
END_IF

previousState := _OperationalState;

_OperationalState := state;

__TRY
	OnOperationalStateChanged(previousState);
__CATCH
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="Stop" Id="{7d81c2ed-cf1e-4941-91df-b5092c404637}">
      <Declaration><![CDATA[{attribute 'TcRpcEnable':='1'}
METHOD FINAL Stop
VAR_INPUT
	reason : WSTRING(255) := "External stop";
END_VAR
VAR
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;	

	i : Core.INT_INDEX;
	
	child : IChildAutomationComponent;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT _Enabled OR_ELSE _OperationalState <> OPERATIONAL_STATE.WORKING THEN
	RETURN;
END_IF

SetState(OPERATIONAL_STATE.STOPPED, reason);

FOR i := 0 TO InternalChildCount - 1 DO
	__TRY
		child := InternalTryGetChildByIndex(i); 
		
		IF child.Enabled THEN		
			child.Stop(Core.WideStrings.Concat255("Parent stopped. Reason: ", reason));
		END_IF			
	__CATCH(exceptionCode)
		exception := Core.ExceptionManager.GetLastException(exceptionCode);	
		
		Core.LogManager.TryLogException(exception, Core.ERROR_SEVERITY.CRITICAL, "AutomationComponent", "AutomationComponent.Stop");
	__ENDTRY
END_FOR]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>