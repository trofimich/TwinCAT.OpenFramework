FUNCTION_BLOCK ABSTRACT AutomationComponent EXTENDS Core.Object IMPLEMENTS IAutomationComponent
VAR
	_Name : WSTRING;

	_Parent : IParentAutomationComponent;
	
	_Enabled : BOOL := TRUE;
	
	_ExceptionSeverityResolver : Core.IExceptionSeverityResolver;
	
	_OperationalState : OPERATIONAL_STATE;	
	_OperationalStateReason : WSTRING(255);	

	_InitializationTimer : Tc2_Standard.TON;
	
	_Error : Core.ERROR;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Folder Name="MembersToOverride" Id="{4de05775-7645-48a4-a52c-fd6f5df57e0a}">
      <Folder Name="Disable" Id="{6b20c619-c34d-4cfe-837d-5610095db22e}" />
      <Folder Name="Enable" Id="{5f6d993c-ed55-43ec-8695-103564140e0d}" />
      <Folder Name="Execute" Id="{8b1a2ad4-edb5-41ef-ac33-98eb7d27d61c}" />
      <Folder Name="Initialization" Id="{ceb990ba-3a7e-4d55-a1af-018a3069f9f8}" />
      <Folder Name="Recover" Id="{e634e265-1169-4c94-be12-8c2aba6db471}" />
      <Folder Name="Reset" Id="{003cc016-63c3-45f5-83a5-ccc4de40c6ed}" />
    </Folder>
    <Folder Name="Service methods" Id="{2407a0ab-9cfa-412f-8f97-557822eedcca}" />
    <Method Name="DoRecover" Id="{d0fb6471-c42a-444a-b8e5-c9978c9d7c43}" FolderPath="Service methods\">
      <Declaration><![CDATA[METHOD PROTECTED FINAL DoRecover
VAR
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;	
	severity : Core.ERROR_SEVERITY;
	
	i : Core.INT_INDEX;
		
	child : IChildAutomationComponent;	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_Error.Clear();

__TRY
	OnBeforeChildrenRecover();
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, 'OnBeforeChildrenRecover');

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.FAULTED, "OnBeforeChildrenRecover error");		
	END_IF
__ENDTRY

FOR i := 0 TO InternalChildCount - 1 DO
	child := InternalTryGetChildByIndex(i);
	
	IF child.Enabled AND_THEN child.OperationalState = OPERATIONAL_STATE.OPERATIONAL AND_THEN child.HasError THEN
		child.Recover();
		
		IF child.HasError AND_THEN child.Error.Severity = Core.ERROR_SEVERITY.CRITICAL THEN
			SetError(child.Error);
			SetState(OPERATIONAL_STATE.FAULTED, "Child Recover error");		
		END_IF
	END_IF
END_FOR

__TRY
	OnAfterChildrenRecover();
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, 'OnAfterChildrenRecover');

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.FAULTED, "OnAfterChildrenRecover error");		
	END_IF
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Property Name="Enabled" Id="{aa3b4270-b240-4ce9-898f-afdfb0a11b5d}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL Enabled : BOOL]]></Declaration>
      <Get Name="Get" Id="{cbdce78d-e4f1-4903-acbe-f5f5552fc11c}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Enabled := _Enabled;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{c2ea677c-f5dd-4c98-93ce-34ce7d6752db}">
        <Declaration><![CDATA[VAR
	i : Core.INT_INDEX;
	
	child : IChildAutomationComponent;
END_VAR]]></Declaration>
        <Implementation>
          <ST><![CDATA[IF _Enabled = Enabled THEN
	RETURN;
END_IF

IF Enabled THEN
	OnBeforeChildrenEnable();
ELSE
	OnBeforeChildrenDisable();
END_IF

FOR i := 0 TO InternalChildCount - 1 DO
	child := InternalTryGetChildByIndex(i);
	
	IF child <> 0 THEN
		child.Enabled := Enabled;
	END_IF
END_FOR

IF Enabled THEN
	OnAfterChildrenEnable();
ELSE
	OnAfterChildrenDisable();
END_IF

_Enabled := Enabled;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Property Name="Error" Id="{5fa83344-3a33-4d67-90ca-8bcde7966cab}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL Error : REFERENCE TO Core.ERROR ]]></Declaration>
      <Get Name="Get" Id="{235d8903-5057-4d40-bc79-b2feb6c602fe}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Error REF= _Error;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="ExceptionSeverityResolver" Id="{1a34f3ab-0c99-4c37-a4c2-b66ddf520c5c}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL ExceptionSeverityResolver : Core.IExceptionSeverityResolver]]></Declaration>
      <Get Name="Get" Id="{ce35d64c-dff0-408b-9486-ad31df2e678c}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[ExceptionSeverityResolver := _ExceptionSeverityResolver;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{0155988e-66c6-4ccf-bcd7-dfe280f4b6d7}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[IF ExceptionSeverityResolver <> 0 THEN
	_ExceptionSeverityResolver := ExceptionSeverityResolver;
ELSE
	_ExceptionSeverityResolver := Core.Exceptions.AnyExceptionToCriticalSeverityResolver;
END_IF]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Method Name="Execute" Id="{0c62a304-be7d-4b17-9ec6-dcdf997a75e1}">
      <Declaration><![CDATA[METHOD FINAL Execute
VAR
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;	
	severity : Core.ERROR_SEVERITY;
	
	i : Core.INT_INDEX;
		
	child : IChildAutomationComponent;	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT Enabled OR_ELSE (_OperationalState <> OPERATIONAL_STATE.OPERATIONAL AND_THEN _OperationalState <> OPERATIONAL_STATE.FAULTED) THEN
	RETURN;
END_IF

// automatic non-critical error recovering
IF _OperationalState = OPERATIONAL_STATE.OPERATIONAL AND_THEN HasError AND_THEN _Error.Severity <> Core.ERROR_SEVERITY.CRITICAL THEN
	DoRecover();
END_IF

// before execute processing
__TRY
	OnBeforeExecute();
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, 'OnBeforeExecute');

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.FAULTED, "OnBeforeExecute error");		
	END_IF
__ENDTRY

// execution processing
CASE _OperationalState OF
	OPERATIONAL_STATE.OPERATIONAL:
		__TRY
			OnWorking();
		__CATCH(exceptionCode)
			exception := Core.ExceptionManager.GetLastException(exceptionCode);	

			severity := _ExceptionSeverityResolver.GetSeverity(exception, 'OnWorking');

			SetException(exception, severity);
		
			IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
				SetState(OPERATIONAL_STATE.FAULTED, "OnWorking error");		
			END_IF
		__ENDTRY	
		
	OPERATIONAL_STATE.FAULTED:
		__TRY
			OnFault();	
		__CATCH(exceptionCode)
			exception := Core.ExceptionManager.GetLastException(exceptionCode);

			severity := _ExceptionSeverityResolver.GetSeverity(exception, 'OnFault');	
		__ENDTRY	
END_CASE

// after execute processing
__TRY
	OnAfterExecute();
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, 'OnAfterExecute');

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.FAULTED, "OnAfterExecute error");		
	END_IF
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{bf2ff865-6631-4d1d-87f4-db36001851c5}">
      <Declaration><![CDATA[METHOD FB_init : BOOL
VAR_INPUT
	(* if TRUE, the retain variables are initialized (warm start / cold start)*)
	bInitRetains	: BOOL;
	(* if TRUE, the instance afterwards gets moved into the copy code (online change)*)
	bInCopyCode	: BOOL;
	name : WSTRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_Name := SEL(Core.WideStrings.IsNullOrWhiteSpace(name), name, GetDefaultName());

_ExceptionSeverityResolver := Core.Exceptions.AnyExceptionToCriticalSeverityResolver;]]></ST>
      </Implementation>
    </Method>
