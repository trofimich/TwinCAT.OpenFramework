    <Property Name="InitializationTimeout" Id="{9b430821-2485-45c1-aea1-812b2962dbb2}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL InitializationTimeout : TIME]]></Declaration>
      <Get Name="Get" Id="{87c850fb-dc27-4c26-beea-f228fa9042e3}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[InitializationTimeout := _InitializationTimer.PT;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{496bac58-2886-40a5-a9c9-db583b496ce0}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[_InitializationTimer.PT := InitializationTimeout;]]></ST>
