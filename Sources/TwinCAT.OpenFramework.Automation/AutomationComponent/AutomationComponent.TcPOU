FUNCTION_BLOCK ABSTRACT AutomationComponent EXTENDS Core.Object IMPLEMENTS IAutomationComponent
VAR
	_Name : WSTRING;

	_Parent : IParentAutomationComponent;
	
	_Enabled : BOOL := TRUE;
	
	_OperationalState : OPERATIONAL_STATE;	
	_OperationalStateReason : WSTRING(255);	

	_InitializationTimer : Tc2_Standard.TON;
	
	_Error : Core.ERROR;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Folder Name="MembersToOverride" Id="{4de05775-7645-48a4-a52c-fd6f5df57e0a}">
      <Folder Name="Disable" Id="{6b20c619-c34d-4cfe-837d-5610095db22e}" />
      <Folder Name="Enable" Id="{5f6d993c-ed55-43ec-8695-103564140e0d}" />
      <Folder Name="Execute" Id="{8b1a2ad4-edb5-41ef-ac33-98eb7d27d61c}" />
      <Folder Name="Initialization" Id="{ceb990ba-3a7e-4d55-a1af-018a3069f9f8}" />
      <Folder Name="Reset" Id="{003cc016-63c3-45f5-83a5-ccc4de40c6ed}" />
      <Folder Name="Stopped" Id="{7a34d7d3-aad8-41c0-a6d0-358b644ba2ac}" />
      <Folder Name="Working" Id="{aa2c7b51-8a55-4e58-a0d2-1dc8814c9e15}" />
    </Folder>
    <Folder Name="Service methods" Id="{2407a0ab-9cfa-412f-8f97-557822eedcca}" />
    <Method Name="Disable" Id="{0d1971e1-5f59-4975-85f2-7a8ffd650e1f}">
      <Declaration><![CDATA[METHOD FINAL Disable
VAR
	i : Core.INT_INDEX;
	
	child : IChildAutomationComponent;
END_VAR
VAR_INST
	disabling : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT _Enabled OR_ELSE disabling THEN
	RETURN;
END_IF

disabling := TRUE;

__TRY
	OnBeforeChildrenDisable();
	
	FOR i := 0 TO InternalChildCount - 1 DO
		child := InternalTryGetChildByIndex(i);
		
		IF child <> 0 THEN
			child.Disable();
		END_IF
	END_FOR
	
	OnAfterChildrenDisable();
	
	_Enabled := FALSE;
	
	disabling := FALSE;	
__CATCH		
	disabling := FALSE;
	
	Core.ExceptionManager.ReThrowLastException();
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="doStop" Id="{80c0471d-00f1-4378-ac91-3dd4df9a0e3a}" FolderPath="Service methods\">
      <Declaration><![CDATA[METHOD PRIVATE FINAL doStop
VAR
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;	
	severity : Core.ERROR_SEVERITY;

	i : Core.INT_INDEX;
	
	child : IChildAutomationComponent;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[__TRY
	OnBeforeChildrenStopped();
__CATCH(exceptionCode)
	exception := Core.ExceptionManager.GetLastException(exceptionCode);	

	severity := OnGetExceptionSeverity(exception, AUTOMATION_COMPONENT_EXCEPTION_CATCH_POINT.ON_BEFORE_CHILDREN_STOPPED);

	Core.LogManager.TryLogException(exception, severity, "AutomationComponent", "AutomationComponent.OnBeforeChildrenStopped");
__ENDTRY	

FOR i := 0 TO InternalChildCount - 1 DO
	child := InternalTryGetChildByIndex(i);
	
	IF child.Enabled AND_THEN (child.OperationalState = OPERATIONAL_STATE.WORKING OR_ELSE child.OperationalState = OPERATIONAL_STATE.STOPPED) THEN
		child.Execute();
	END_IF
END_FOR

__TRY
	OnAfterChildrenStopped();
__CATCH(exceptionCode)
	exception := Core.ExceptionManager.GetLastException(exceptionCode);	

	severity := OnGetExceptionSeverity(exception, AUTOMATION_COMPONENT_EXCEPTION_CATCH_POINT.ON_AFTER_CHILDREN_STOPPED);

	Core.LogManager.TryLogException(exception, severity, "AutomationComponent", "AutomationComponent.OnAfterChildrenStopped");
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="doWork" Id="{cf5073da-ab43-4e41-bdd6-522461cbde05}" FolderPath="Service methods\">
      <Declaration><![CDATA[METHOD PRIVATE doWork
VAR
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;	
	severity : Core.ERROR_SEVERITY;

	i : Core.INT_INDEX;
	
	child : IChildAutomationComponent;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[// automatic non-critical error recovering
IF _OperationalState = OPERATIONAL_STATE.WORKING AND_THEN HasError AND_THEN _Error.Severity <> Core.ERROR_SEVERITY.CRITICAL THEN
	_Error.Clear();
	
	__TRY
		OnRecover();
	__CATCH(exceptionCode)		
		exception := Core.ExceptionManager.GetLastException(exceptionCode);
						
		severity := OnGetExceptionSeverity(exception, AUTOMATION_COMPONENT_EXCEPTION_CATCH_POINT.ON_RECOVER);
	
		SetException(exception, severity);
	
		IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
			SetState(OPERATIONAL_STATE.STOPPED, "OnRecover error");		
			RETURN;
		END_IF		
	__ENDTRY
END_IF

__TRY
	OnBeforeChildrenWorking();
__CATCH(exceptionCode)
	exception := Core.ExceptionManager.GetLastException(exceptionCode);	

	severity := OnGetExceptionSeverity(exception, AUTOMATION_COMPONENT_EXCEPTION_CATCH_POINT.ON_BEFORE_CHILDREN_WORKING);

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.STOPPED, "OnBeforeChildrenWorking error");
		RETURN;		
	END_IF
__ENDTRY	

FOR i := 0 TO InternalChildCount - 1 DO
	child := InternalTryGetChildByIndex(i);
	
	IF child.Enabled AND_THEN (child.OperationalState = OPERATIONAL_STATE.WORKING OR_ELSE child.OperationalState = OPERATIONAL_STATE.STOPPED) THEN
		child.Execute();
		
		IF child.HasError AND_THEN child.Error.Severity = Core.ERROR_SEVERITY.CRITICAL THEN
			SetError(child.Error);
			SetState(OPERATIONAL_STATE.STOPPED, Core.WideStrings.Concat255("Child[", TO_WSTRING(i), "(", child.Name, ")].Execute error"));		
			RETURN;
		END_IF
	END_IF
END_FOR

__TRY
	OnAfterChildrenWorking();
__CATCH(exceptionCode)
	exception := Core.ExceptionManager.GetLastException(exceptionCode);	

	severity := OnGetExceptionSeverity(exception, AUTOMATION_COMPONENT_EXCEPTION_CATCH_POINT.ON_AFTER_CHILDREN_WORKING);

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.STOPPED, "OnAfterChildrenWorking error");
		RETURN;		
	END_IF
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="Enable" Id="{8c41e56c-f727-473a-87e6-57596090402c}">
      <Declaration><![CDATA[METHOD FINAL Enable
VAR_INPUT
	includeChildren : BOOL := TRUE;
END_VAR
VAR
	i : Core.INT_INDEX;
	
	child : IChildAutomationComponent;

	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;	
END_VAR
VAR_INST
	enabling : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF _Enabled OR_ELSE enabling THEN
	RETURN;
END_IF

enabling := TRUE;

__TRY
	OnBeforeChildrenEnable();
	
	IF includeChildren THEN
		FOR i := 0 TO InternalChildCount - 1 DO
			child := InternalTryGetChildByIndex(i);
			
			IF child <> 0 THEN
				child.Enable(includeChildren);
			END_IF
		END_FOR	
	END_IF
	
	OnAfterChildrenEnable();
	
	IF _Parent <> 0 AND_THEN NOT _Parent.Enabled THEN
		_Parent.Enable(FALSE);
	END_IF
	
	_Enabled := TRUE;
	
	enabling := FALSE;
__CATCH		
	enabling := FALSE;
	
	Core.ExceptionManager.ReThrowLastException();
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Property Name="Enabled" Id="{aa3b4270-b240-4ce9-898f-afdfb0a11b5d}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL Enabled : BOOL]]></Declaration>
      <Get Name="Get" Id="{cbdce78d-e4f1-4903-acbe-f5f5552fc11c}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Enabled := _Enabled;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="Error" Id="{5fa83344-3a33-4d67-90ca-8bcde7966cab}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL Error : REFERENCE TO Core.ERROR ]]></Declaration>
      <Get Name="Get" Id="{235d8903-5057-4d40-bc79-b2feb6c602fe}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Error REF= _Error;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="Execute" Id="{0c62a304-be7d-4b17-9ec6-dcdf997a75e1}">
      <Declaration><![CDATA[METHOD FINAL Execute
VAR
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;	
	severity : Core.ERROR_SEVERITY;
	
	i : Core.INT_INDEX;
		
	child : IChildAutomationComponent;	
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT Enabled OR_ELSE (_OperationalState <> OPERATIONAL_STATE.WORKING AND_THEN _OperationalState <> OPERATIONAL_STATE.STOPPED) THEN
	RETURN;
END_IF

// before execute processing
__TRY
	OnBeforeExecute();
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := OnGetExceptionSeverity(exception, AUTOMATION_COMPONENT_EXCEPTION_CATCH_POINT.ON_BEFORE_EXECUTE);

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.STOPPED, "OnBeforeExecute error");		
	END_IF
__ENDTRY

// execution processing
CASE _OperationalState OF
	OPERATIONAL_STATE.WORKING:
		doWork();
		
	OPERATIONAL_STATE.STOPPED:
		doStop();	
END_CASE

// after execute processing
__TRY
	OnAfterExecute();
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := OnGetExceptionSeverity(exception, AUTOMATION_COMPONENT_EXCEPTION_CATCH_POINT.ON_AFTER_EXECUTE);

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.STOPPED, "OnAfterExecute error");		
	END_IF
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{bf2ff865-6631-4d1d-87f4-db36001851c5}">
      <Declaration><![CDATA[METHOD FB_init : BOOL
VAR_INPUT
	(* if TRUE, the retain variables are initialized (warm start / cold start)*)
	bInitRetains	: BOOL;
	(* if TRUE, the instance afterwards gets moved into the copy code (online change)*)
	bInCopyCode	: BOOL;
	name : WSTRING;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_Name := SEL(Core.WideStrings.IsNullOrWhiteSpace(name), name, GetDefaultName());]]></ST>
      </Implementation>
    </Method>
