      </Set>
    </Property>
    <Method Name="Initialize" Id="{dc8b4ac8-c6c4-4b95-8f4f-93a38c521c55}">
      <Declaration><![CDATA[METHOD FINAL Initialize : BOOL
VAR
	i : Core.INT_INDEX;
	
	parent : IChildAutomationComponent;
	child : IChildAutomationComponent;
	
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;
	
	initializationTimeoutException : Core.TimeoutException;
	notSpecifiedException : Core.DataMemberNotSpecifiedException;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF _OperationalState <> OPERATIONAL_STATE.INITIALIZING THEN
	RETURN;
END_IF

__TRY
	_InitializationTimer(IN := TRUE, PT := Parameters.InitializationTimeout);
	
	IF _InitializationTimer.Q THEN		
		initializationTimeoutException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), _InitializationTimer.PT, Core.WideStrings.Concat255("Initialization timeout ", TO_WSTRING(_InitializationTimer.PT), " elapsed"));
	END_IF
	
	IF __QUERYINTERFACE(THIS^, parent) AND_THEN NOT parent.HasParent THEN
		notSpecifiedException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), 'Parent');			
	END_IF

	OnBeforeChildrenInitializing();
	
	Initialize := TRUE;

	FOR i := 0 TO InternalChildCount - 1 DO
		child := InternalTryGetChildByIndex(i);

		IF child = 0 THEN
			notSpecifiedException.ThrowByObject(THIS^, __POUNAME(), __POSITION(), Core.Strings.Concat255('Child[', TO_STRING(i), ']'));			
		END_IF
			
		Initialize := Initialize AND child.Initialize();
	END_FOR

	Initialize := Initialize AND OnAfterChildrenInitializing();
	
	IF Initialize THEN
		SetState(OPERATIONAL_STATE.WORKING, "Successfull initialization");
	END_IF	
__CATCH(exceptionCode)
	SetState(OPERATIONAL_STATE.INVALID, "Initialization error");
	
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
	
	SetException(exception, Core.ERROR_SEVERITY.CRITICAL);					
__ENDTRY]]></ST>
      </Implementation>
    </Method>
