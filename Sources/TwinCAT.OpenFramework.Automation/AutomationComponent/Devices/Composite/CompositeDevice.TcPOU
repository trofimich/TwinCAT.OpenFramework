    <Method Name="OnPostSubDeviceInitializing" Id="{92cef328-43a3-40eb-82aa-0ebd1e9574ce}" FolderPath="Methods to override\Initialization\">
      <Declaration><![CDATA[METHOD PROTECTED OnPostSubDeviceInitializing : BOOL]]></Declaration>
      <Implementation>
        <ST><![CDATA[OnPostSubDeviceInitializing := TRUE;]]></ST>
