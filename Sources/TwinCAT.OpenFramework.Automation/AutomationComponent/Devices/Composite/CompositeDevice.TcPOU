    <Method Name="ProcessInput" Id="{169f608c-73af-42d0-b266-fd32baea3032}">
      <Declaration><![CDATA[METHOD FINAL ProcessInput
VAR
	i : INT;
	
	inputSubDevice : IInputDevice;
	
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;
	severity : Core.ERROR_SEVERITY;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[__TRY
	OnInputProcessing();
__CATCH(exceptionCode)	
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, __POUNAME());

	SetException(exception, severity);		
__ENDTRY
	
IF __ISVALIDREF(SubDevices) AND_THEN _SubDeviceCount > 0 THEN
	FOR i := 0 TO _SubDeviceCount - 1 DO
		IF NOT SubDevices[i].Enabled OR_ELSE NOT __QUERYINTERFACE(SubDevices[i], inputSubDevice) THEN
			CONTINUE;
		END_IF
		
		inputSubDevice.ProcessInput();
		
		IF inputSubDevice.HasError THEN
			SetError(inputSubDevice.Error);				
		END_IF
	END_FOR	
END_IF

__TRY	
	OnInputProcessed();	
__CATCH(exceptionCode)	
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, __POUNAME());

	SetException(exception, severity);	
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="ProcessOutput" Id="{d8822de7-f12d-43fe-bdcd-3812e5246f80}">
      <Declaration><![CDATA[METHOD FINAL ProcessOutput
VAR
	i : INT;
	
	outputSubDevice : IOutputDevice;
	
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;
	severity : Core.ERROR_SEVERITY;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[__TRY
	OnOutputProcessing();
__CATCH(exceptionCode)	
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, __POUNAME());

	SetException(exception, severity);	
__ENDTRY

IF __ISVALIDREF(SubDevices) AND_THEN _SubDeviceCount > 0 THEN
	FOR i := 0 TO _SubDeviceCount - 1 DO
		IF NOT SubDevices[i].Enabled OR_ELSE NOT __QUERYINTERFACE(SubDevices[i], outputSubDevice) THEN
			CONTINUE;
		END_IF
		
		outputSubDevice.ProcessOutput();
		
		IF outputSubDevice.HasError THEN
			SetError(outputSubDevice.Error);				
		END_IF
	END_FOR	
END_IF

__TRY
	OnOutputProcessed();
__CATCH(exceptionCode)	
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, __POUNAME());

	SetException(exception, severity);	
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="Recover" Id="{c36a31ad-c0cc-483f-b70d-2d0540bc16c1}">
      <Declaration><![CDATA[METHOD FINAL Recover 
VAR
	i : DINT;
	
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;
	severity : Core.ERROR_SEVERITY;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF _Error.Severity <> Core.ERROR_SEVERITY.CRITICAL THEN
	_Error.Clear();
	
	IF __ISVALIDREF(SubDevices) AND_THEN _SubDeviceCount > 0 THEN
		FOR i := 0 TO _SubDeviceCount - 1 DO
			IF SubDevices[i].Enabled THEN
				SubDevices[i].Recover();
				
				IF SubDevices[i].HasError THEN
					SetError(SubDevices[i].Error);
					RETURN;
				END_IF				
			END_IF
		END_FOR
	END_IF
	
	__TRY
		OnRecover();
	__CATCH(exceptionCode)	
		exception := Core.ExceptionManager.GetLastException(exceptionCode);
						
		severity := _ExceptionSeverityResolver.GetSeverity(exception, __POUNAME());
	
		SetException(exception, severity);	
	__ENDTRY
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="Reset" Id="{cd780f57-7bd4-43c5-8c43-3bebeb98d902}">
      <Declaration><![CDATA[METHOD FINAL Reset
VAR
	i : DINT;
	
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;
	severity : Core.ERROR_SEVERITY;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_Error.Clear();

IF __ISVALIDREF(SubDevices) AND_THEN _SubDeviceCount > 0 THEN
	FOR i := 0 TO _SubDeviceCount - 1 DO
		IF SubDevices[i].Enabled THEN 
			SubDevices[i].Reset();
			
			IF SubDevices[i].HasError THEN
				SetError(SubDevices[i].Error);
				RETURN;
			END_IF				
		END_IF
	END_FOR
END_IF

__TRY
	OnReset();
__CATCH(exceptionCode)	
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, __POUNAME());

	SetException(exception, severity);	
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Property Name="SubDeviceCount" Id="{8fe9b9a1-849f-40ca-953d-31f713106361}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL SubDeviceCount : INT]]></Declaration>
      <Get Name="Get" Id="{efd6679f-7abb-4ba2-907a-97a3a87b2c0a}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[SubDeviceCount := _SubDeviceCount;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="SubDevices" Id="{5eb8cc14-af21-41a6-964e-854d2107c6da}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY ABSTRACT SubDevices : REFERENCE TO ARRAY [0.._SubDeviceCount - 1] OF IDevice]]></Declaration>
      <Get Name="Get" Id="{92c9163e-e171-4a3b-8e8e-5251e6af78eb}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="TryGetSubDeviceByIndex" Id="{e2e78db3-9f06-4b18-b030-d1b97840dae7}">
      <Declaration><![CDATA[METHOD FINAL TryGetSubDeviceByIndex : IDevice
VAR_INPUT
	index : BYTE;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF index < 0 OR_ELSE index >= _SubDeviceCount OR_ELSE NOT __ISVALIDREF(SubDevices) THEN
	RETURN;
END_IF

TryGetSubDeviceByIndex := SubDevices[index];]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>