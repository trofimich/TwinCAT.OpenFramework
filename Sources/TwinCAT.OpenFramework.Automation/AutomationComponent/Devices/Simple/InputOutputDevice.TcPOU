    <Method Name="ProcessInput" Id="{c8339c8d-4067-4f4a-a590-969bcf06fcfd}">
      <Declaration><![CDATA[METHOD FINAL ProcessInput
VAR
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;
	severity : Core.ERROR_SEVERITY;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[__TRY
	OnProcessInput();
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, 'OnProcessInput');

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
		SetState(OPERATIONAL_STATE.FAULTED, "OnProcessInput error");		
	END_IF
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Method Name="ProcessOutput" Id="{a26c06ee-82b7-4764-95fa-cf1bbe29daa3}">
      <Declaration><![CDATA[METHOD FINAL ProcessOutput
VAR
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : Core.IException;
	severity : Core.ERROR_SEVERITY;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[__TRY
	OnProcessOutput();
__CATCH(exceptionCode)		
	exception := Core.ExceptionManager.GetLastException(exceptionCode);
					
	severity := _ExceptionSeverityResolver.GetSeverity(exception, 'OnProcessOutput');

	SetException(exception, severity);

	IF severity = Core.ERROR_SEVERITY.CRITICAL THEN
