    <Method Name="OnProcessInput" Id="{94e71efd-bb71-4095-9cb0-5f4f8a38c0d8}" FolderPath="Methods to override\">
      <Declaration><![CDATA[METHOD PROTECTED ABSTRACT OnProcessInput]]></Declaration>
