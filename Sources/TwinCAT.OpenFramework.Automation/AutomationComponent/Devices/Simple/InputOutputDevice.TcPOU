    <Method Name="OnProcessOutput" Id="{6751103a-6dfb-417d-8b22-87cbdffa3af8}" FolderPath="Methods to override\">
      <Declaration><![CDATA[METHOD PROTECTED ABSTRACT OnProcessOutput]]></Declaration>
