{attribute 'no_explicit_call' := 'do not call this function block directly'} 
FUNCTION_BLOCK AutomationRunner EXTENDS Core.Object IMPLEMENTS IAutomationRunner
VAR_OUTPUT
	InitializationErrorMessage : Core.ERROR_MESSAGE;
END_VAR
VAR
	_ClassName : STRING := __POUNAME();

	_State : AUTOMATION_RUNNER_STATE;
END_VAR
VAR_STAT
	{attribute 'hide'} 
    _InstanceCounter : BYTE := 0;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Property Name="ClassName" Id="{12ea2f4d-4597-416e-8305-e7d74fbf4c45}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY ClassName : STRING]]></Declaration>
      <Get Name="Get" Id="{9841726e-851b-4678-a1b5-99c8a1cc58e0}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[ClassName := _ClassName;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="CodeExecutionPhase" Id="{efb7b0b9-70db-41a4-b4ff-ce52174473b3}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL CodeExecutionPhase : BOOL]]></Declaration>
      <Get Name="Get" Id="{cecc6bd9-038a-46c9-8b45-fbc1f53aeac6}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[CodeExecutionPhase := GlobalState.CodeExecutionPhase;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Property Name="CycleCounter" Id="{48d69b36-ca3c-42e8-81f7-1847fca33118}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY FINAL CycleCounter : LWORD]]></Declaration>
      <Get Name="Get" Id="{57f068b8-2ae6-4baf-833c-f4f9332269cb}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[CycleCounter := GlobalState.CycleCounter;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="Execute" Id="{16952208-3067-4c16-b350-7fd85c7e6a7d}">
      <Declaration><![CDATA[METHOD FINAL Execute
VAR_IN_OUT CONSTANT
	controllers : ARRAY [*] OF IAutomationController;
END_VAR
VAR
	i : DINT;
			
	initialized : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[GlobalState.CodeExecutionPhase := TRUE;

Core.SystemDateTimeManager.Execute();		

Core.LogManager.Execute();

IF Core.SystemDateTimeManager.SystemTimeValid THEN
	CASE _State OF
		AUTOMATION_RUNNER_STATE.INITIALIZING:
			IF UPPER_BOUND(controllers, 1) - LOWER_BOUND(controllers, 1) < 0 THEN
				_State := AUTOMATION_RUNNER_STATE.INITIALIZATION_FAILED;		
				InitializationErrorMessage := "No controllers to run";
				RETURN;		
			END_IF

			initialized := TRUE;
			
			FOR i := LOWER_BOUND(controllers, 1) TO UPPER_BOUND(controllers, 1) DO
				IF Controllers[i] = 0 THEN
					_State := AUTOMATION_RUNNER_STATE.INITIALIZATION_FAILED;
					InitializationErrorMessage := Core.WideStrings.Concat255("controller[", TO_WSTRING(i), "] is null");
					EXIT;					
				END_IF

				Controllers[i].Initialize();
				
				CASE Controllers[i].State OF
					AUTOMATION_CONTROLLER_STATE.FAULT:
						_State := AUTOMATION_RUNNER_STATE.INITIALIZATION_FAILED;
						InitializationErrorMessage := Core.WideStrings.Concat255("controller[", TO_WSTRING(i), "] failed");
						EXIT;
						
					AUTOMATION_CONTROLLER_STATE.INITIAL:
						initialized := FALSE;						
				END_CASE
			END_FOR		
			
			IF initialized THEN
				_State := AUTOMATION_RUNNER_STATE.RUNNING;
			END_IF
		
		AUTOMATION_RUNNER_STATE.RUNNING:
			FOR i := LOWER_BOUND(controllers, 1) TO UPPER_BOUND(controllers, 1) DO
				Controllers[i].Execute();			
			END_FOR		
	END_CASE

END_IF

Core.ExceptionManager.Cleanup();
Core.DynamicMemoryManager.CleanupMemory();

GlobalState.CycleCounter := GlobalState.CycleCounter + 1;
GlobalState.CodeExecutionPhase := FALSE;]]></ST>
      </Implementation>
    </Method>
    <Method Name="FB_init" Id="{9dcb424f-eaa9-4a0f-923f-5afac333563a}">
      <Declaration><![CDATA[METHOD FB_init : BOOL
VAR_INPUT
	(* if TRUE, the retain variables are initialized (warm start / cold start)*)
	bInitRetains	: BOOL;
	(* if TRUE, the instance afterwards gets moved into the copy code (online change)*)
	bInCopyCode	: BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[_InstanceCounter := _InstanceCounter + 1;]]></ST>
      </Implementation>
    </Method>
    <Property Name="NamespaceName" Id="{d334c947-0a4c-4dfb-8401-47625a37779f}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY NamespaceName : STRING]]></Declaration>
