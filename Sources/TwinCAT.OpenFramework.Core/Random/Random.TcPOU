<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="Random" Id="{73f398d9-0f56-4400-b482-926f5b7248ad}" SpecialFunc="None">
    <Declaration><![CDATA[(*

