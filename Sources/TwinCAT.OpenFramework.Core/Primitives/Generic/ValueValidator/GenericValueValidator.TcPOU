<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="GenericValueValidator" Id="{a6d5904d-3010-444c-98c8-80a1917cd203}" SpecialFunc="None">
    <Declaration><![CDATA[(*

.. <legal notes>

legal notes
