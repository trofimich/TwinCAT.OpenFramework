    <Method Name="FromObject" Id="{8021dfa6-6b1b-4231-914a-01453b2ec899}" FolderPath="FromTyped\">
      <Declaration><![CDATA[METHOD FromObject 
VAR_INPUT
	value : IObject;
	owningMemory : BOOL;
END_VAR
VAR
	argumentNullException : ArgumentNullException;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF value = 0 THEN
	argumentNullException.Throw(CurrentNamespace.Name, ClassName, __POUNAME(), __POSITION(), 'value');
END_IF

DataType := DATA_TYPE.TYPE_OBJECT;
Address := ADR(value);
Size := value.Size;
IsMemoryOwner := owningMemory;]]></ST>
      </Implementation>
    </Method>
