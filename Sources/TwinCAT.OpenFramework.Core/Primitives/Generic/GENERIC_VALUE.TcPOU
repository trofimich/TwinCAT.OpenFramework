    <Method Name="ReleaseOwnedMemory" Id="{9937fc92-8120-434b-ac91-5b20bd6f7de6}" FolderPath="Service methods\">
      <Declaration><![CDATA[METHOD ReleaseOwnedMemory]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF IsMemoryOwner THEN
	DynamicMemoryManager.ReleaseDynamicMemory(Address, DataType = DATA_TYPE.TYPE_OBJECT);
END_IF]]></ST>
      </Implementation>
    </Method>
