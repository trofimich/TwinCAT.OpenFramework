    <Method Name="FromAny" Id="{6ea8f682-f65a-4f72-b981-df5fc5f1ef43}" FolderPath="FromTyped\">
      <Declaration><![CDATA[METHOD FromAny 
VAR_INPUT
	value : ANY;
	owningMemory : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[FromAnyType(value, owningMemory);]]></ST>
      </Implementation>
    </Method>
    <Method Name="FromAnyType" Id="{58f5fed2-ee58-4bb7-b5fb-7380db0fc95f}">
      <Declaration><![CDATA[METHOD FromAnyType 
VAR_INPUT
	value : __System.AnyType;
	owningMemory : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[DataType := AnyTypeHelper.GetDataTypeBySystemAnyType(value);
Size := TO_ULINT(value.diSize);
IsMemoryOwner := owningMemory;

IF IsMemoryOwner AND_THEN value.pValue <> 0 AND_THEN value.diSize > 0 THEN
	Address := __NEW(BYTE, TO_UDINT(value.diSize));	
	Tc2_System.MEMCPY(Address, value.pValue, TO_UDINT(value.diSize));
END_IF]]></ST>
      </Implementation>
    </Method>
    <Method Name="FromBool" Id="{300fdb7d-c11b-4beb-ac08-bd598c147a8c}" FolderPath="FromTyped\">
      <Declaration><![CDATA[METHOD FromBool 
VAR_INPUT
	value : REFERENCE TO BOOL;
	owningMemory : BOOL;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[DataType := DATA_TYPE.TYPE_BOOL;
Address := ADR(value);
Size := XSIZEOF(value);
IsMemoryOwner := owningMemory;]]></ST>
      </Implementation>
    </Method>
