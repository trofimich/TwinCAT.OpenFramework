.. </legal notes>

*)

PROGRAM LogManager
VAR_INPUT
	MessageNumberFormat : LOG_MESSAGE_NUMBER_FORMAT := LOG_MESSAGE_NUMBER_FORMAT.SEQUENTIAL_BY_CATEGORY;
END_VAR
VAR_OUTPUT
	TotalMessageCounter : ULINT;
	FilteredMessageCounter : ULINT;
	
	TotalMessageByCategoryCounters : ARRAY [LOG_CATEGORY.DEBUG .. LOG_CATEGORY.CRITICAL_ERROR] OF ULINT;   
	FilteredMessageByCategoryCounters : ARRAY [LOG_CATEGORY.DEBUG .. LOG_CATEGORY.CRITICAL_ERROR] OF ULINT;   
END_VAR
VAR
	_DefaultLogger : AdsLogger;
	_Logger : ILogger;	
	_Filter : ILogFilter;  
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[]]></ST>
    </Implementation>
    <Method Name="Execute" Id="{13c3c36e-9fa4-45b8-9a63-156fe14d049b}">
      <Declaration><![CDATA[METHOD Execute
VAR
	exceptionCode : __SYSTEM.ExceptionCode;
	exception : IException;
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[__TRY
	Logger.Execute();
__CATCH(exceptionCode)
	exception := ExceptionManager.GetLastException(exceptionCode);
	
	_DefaultLogger.TryLogException(exception, ERROR_SEVERITY.ERROR);
__ENDTRY]]></ST>
      </Implementation>
    </Method>
    <Property Name="Filter" Id="{b6f1f4aa-92b0-409e-ad33-af6c50416e83}">
      <Declaration><![CDATA[PROPERTY Filter : ILogFilter]]></Declaration>
      <Get Name="Get" Id="{31e6a597-f4cb-45a7-bcf1-c6f162ef07f2}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[Filter := _Filter;]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{3a6b37ff-c92d-4d4c-a4cf-30b8093e5043}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[_Filter := Filter;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Property Name="Logger" Id="{8f399577-3e03-44ae-a287-168cdae9d0ec}">
      <Declaration><![CDATA[PROPERTY Logger : ILogger]]></Declaration>
      <Get Name="Get" Id="{c9c1cefb-1091-483c-b6a3-ca70a961903f}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[IF _Logger = 0 THEN
	Logger := _DefaultLogger;
ELSE
	Logger := _Logger;
END_IF]]></ST>
        </Implementation>
      </Get>
      <Set Name="Set" Id="{82c82d05-b526-431e-b338-c69fda2bdd1a}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[_Logger := Logger;]]></ST>
        </Implementation>
      </Set>
    </Property>
    <Property Name="NamespaceName" Id="{84be6e8d-e2b5-4bd6-ae4f-31889ab0432e}">
      <Declaration><![CDATA[{attribute 'monitoring' := 'call'}
PROPERTY NamespaceName : STRING]]></Declaration>
      <Get Name="Get" Id="{4891555c-102c-47e3-8f69-9a215e109b78}">
        <Declaration><![CDATA[]]></Declaration>
        <Implementation>
          <ST><![CDATA[NamespaceName := CurrentNamespace.Name;]]></ST>
        </Implementation>
      </Get>
    </Property>
    <Method Name="TryLogError" Id="{f8c266fa-1403-48ca-81af-80709466198a}">
      <Declaration><![CDATA[METHOD TryLogError : BOOL
VAR_INPUT
	error : REFERENCE TO ERROR;
	topic1 : WSTRING := "";	
	topic2 : WSTRING := "";	
	topic3 : WSTRING := "";	
	topic4 : WSTRING := "";	
	topic5 : WSTRING := "";	
END_VAR
VAR
	category : LOG_CATEGORY;
	topics : ARRAY [0..4] OF WSTRING; 
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF NOT __ISVALIDREF(error) THEN
	RETURN;
END_IF

category := SEL(error.Severity = ERROR_SEVERITY.CRITICAL, LOG_CATEGORY.ERROR, LOG_CATEGORY.CRITICAL_ERROR); 

TotalMessageCounter := TotalMessageCounter + 1;
TotalMessageByCategoryCounters[category] := TotalMessageByCategoryCounters[category] + 1;

topics[0] := topic1;
topics[1] := topic2;
topics[2] := topic3;
topics[3] := topic4;
topics[4] := topic5;

IF Filter <> 0 AND_THEN NOT Filter.ShouldLog(category, topics) THEN
	RETURN;
END_IF

FilteredMessageCounter := FilteredMessageCounter + 1;
FilteredMessageByCategoryCounters[category] := FilteredMessageByCategoryCounters[category] + 1;

CASE MessageNumberFormat OF
	LOG_MESSAGE_NUMBER_FORMAT.NONE:
		TryLogError := Logger.TryLogError(error);
		
	LOG_MESSAGE_NUMBER_FORMAT.SEQUENTIAL:
		TryLogError := Logger.TryLogError(error, FilteredMessageCounter);
	
	LOG_MESSAGE_NUMBER_FORMAT.SEQUENTIAL_BY_CATEGORY:
		TryLogError := Logger.TryLogError(error, FilteredMessageByCategoryCounters[category]);
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="TryLogException" Id="{bd7d75b2-118d-460f-87a2-4f124e9232ba}">
      <Declaration><![CDATA[METHOD TryLogException : BOOL
VAR_INPUT
	exception : IException;
	severity : ERROR_SEVERITY;
	topic1 : WSTRING := "";	
	topic2 : WSTRING := "";	
	topic3 : WSTRING := "";	
	topic4 : WSTRING := "";	
END_VAR
VAR
	category : LOG_CATEGORY;
	topics : ARRAY [0..4] OF WSTRING; 
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF exception = 0 THEN
	RETURN;
END_IF

category := SEL(severity = ERROR_SEVERITY.CRITICAL, LOG_CATEGORY.ERROR, LOG_CATEGORY.CRITICAL_ERROR); 

TotalMessageCounter := TotalMessageCounter + 1;
TotalMessageByCategoryCounters[category] := TotalMessageByCategoryCounters[category] + 1;

topics[0] := TO_WSTRING(exception.ClassName);
topics[1] := topic1;
topics[2] := topic2;
topics[3] := topic3;
topics[4] := topic4;

IF Filter <> 0 AND_THEN NOT Filter.ShouldLog(category, topics) THEN
	RETURN;
END_IF

FilteredMessageCounter := FilteredMessageCounter + 1;
FilteredMessageByCategoryCounters[category] := FilteredMessageByCategoryCounters[category] + 1;

CASE MessageNumberFormat OF
	LOG_MESSAGE_NUMBER_FORMAT.NONE:
		TryLogException := Logger.TryLogException(exception, severity);
		
	LOG_MESSAGE_NUMBER_FORMAT.SEQUENTIAL:
		TryLogException := Logger.TryLogException(exception, severity, FilteredMessageCounter);
	
	LOG_MESSAGE_NUMBER_FORMAT.SEQUENTIAL_BY_CATEGORY:
		TryLogException := Logger.TryLogException(exception, severity, FilteredMessageByCategoryCounters[category]);
END_CASE]]></ST>
      </Implementation>
    </Method>
    <Method Name="TryLogMessage" Id="{1b41c149-f4d6-4a68-875a-675fa3954ac9}">
      <Declaration><![CDATA[METHOD TryLogMessage : BOOL
VAR_INPUT
	message : ERROR_MESSAGE;
	category : LOG_CATEGORY;
	topic1 : WSTRING := "";	
	topic2 : WSTRING := "";	
	topic3 : WSTRING := "";	
	topic4 : WSTRING := "";	
	topic5 : WSTRING := "";	
END_VAR
VAR
	topics : ARRAY [0..4] OF WSTRING; 
END_VAR]]></Declaration>
      <Implementation>
        <ST><![CDATA[IF message = WideStrings.Empty THEN
	RETURN;
END_IF

TotalMessageCounter := TotalMessageCounter + 1;
TotalMessageByCategoryCounters[category] := TotalMessageByCategoryCounters[category] + 1;

topics[0] := topic1;
topics[1] := topic2;
topics[2] := topic3;
topics[3] := topic4;
topics[4] := topic5;

IF Filter <> 0 AND_THEN NOT Filter.ShouldLog(category, topics) THEN
	RETURN;
END_IF

FilteredMessageCounter := FilteredMessageCounter + 1;
FilteredMessageByCategoryCounters[category] := FilteredMessageByCategoryCounters[category] + 1;

CASE MessageNumberFormat OF
	LOG_MESSAGE_NUMBER_FORMAT.NONE:
		TryLogMessage := Logger.TryLogMessage(category, message);
		
	LOG_MESSAGE_NUMBER_FORMAT.SEQUENTIAL:
		TryLogMessage := Logger.TryLogMessage(category, message, FilteredMessageCounter);
	
	LOG_MESSAGE_NUMBER_FORMAT.SEQUENTIAL_BY_CATEGORY:
		TryLogMessage := Logger.TryLogMessage(category, message, FilteredMessageByCategoryCounters[category]);
END_CASE]]></ST>
      </Implementation>
    </Method>
  </POU>
</TcPlcObject>