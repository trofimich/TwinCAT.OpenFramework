<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="CollectionEmptyException" Id="{4bed74e9-976c-48cb-976a-f2975ddf9c18}" SpecialFunc="None">
    <Declaration><![CDATA[(*

.. <legal notes>

