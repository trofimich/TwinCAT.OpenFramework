<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="StaticCollectionFullException" Id="{0096f1a9-f507-4fb2-a70c-f47e70fe3987}" SpecialFunc="None">
    <Declaration><![CDATA[(*

.. <legal notes>

legal notes
