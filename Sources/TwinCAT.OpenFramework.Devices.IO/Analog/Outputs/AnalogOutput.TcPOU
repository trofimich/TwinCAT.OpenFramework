<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="AnalogOutput" Id="{2baa0bb5-149e-4c48-8457-b1d26d365163}" SpecialFunc="None">
    <Declaration><![CDATA[(*

