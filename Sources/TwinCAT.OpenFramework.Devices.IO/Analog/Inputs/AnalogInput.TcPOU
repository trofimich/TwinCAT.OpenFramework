<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="AnalogInput" Id="{53ded094-f30c-413d-b537-b1168c47757b}" SpecialFunc="None">
    <Declaration><![CDATA[(*

