<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="DigitalOutput" Id="{00c882bb-0de1-4d65-b6f1-d0df694bfb3e}" SpecialFunc="None">
    <Declaration><![CDATA[(*

