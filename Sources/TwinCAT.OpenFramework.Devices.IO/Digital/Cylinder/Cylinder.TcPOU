<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="Cylinder" Id="{6464b634-98cb-4168-a91a-75e90ef38632}" SpecialFunc="None">
    <Declaration><![CDATA[(*

