<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="LoggerTest" Id="{46a5aaeb-be18-4d0f-8490-9efb1449dd48}" SpecialFunc="None">
    <Declaration><![CDATA[(*

