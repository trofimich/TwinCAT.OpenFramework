FUNCTION_BLOCK RangeAnalogValueConverterTest EXTENDS TcUnit.FB_TestSuite
VAR
	_ClassName : STRING := __POUNAME();
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[Test16Bit();
Test32Bit();
Test32Real();]]></ST>
    </Implementation>
