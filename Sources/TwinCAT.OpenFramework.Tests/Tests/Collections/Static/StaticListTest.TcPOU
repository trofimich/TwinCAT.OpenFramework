<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="StaticListTest" Id="{508e208f-a521-41c7-9e7d-1ed13383be68}" SpecialFunc="None">
    <Declaration><![CDATA[(*

.. <legal notes>

