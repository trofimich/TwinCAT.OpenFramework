<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="StaticListTest" Id="{624ab1ea-d3ea-4da5-9d11-4fe6eaa8b579}" SpecialFunc="None">
    <Declaration><![CDATA[(*

