<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="StaticQueueTest" Id="{11fdb459-88a8-4c21-bfca-b5e096c9c5bc}" SpecialFunc="None">
    <Declaration><![CDATA[(*

