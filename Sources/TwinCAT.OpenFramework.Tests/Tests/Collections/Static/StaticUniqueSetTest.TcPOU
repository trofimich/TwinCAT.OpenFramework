<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="StaticUniqueSetTest" Id="{46f65795-2d80-40c9-ba2e-4c7ad5fdcb7f}" SpecialFunc="None">
    <Declaration><![CDATA[(*

