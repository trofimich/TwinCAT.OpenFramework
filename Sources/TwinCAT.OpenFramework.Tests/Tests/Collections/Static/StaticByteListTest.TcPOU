<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="StaticByteListTest" Id="{e82c77d6-5acd-4f3b-a63d-8c6bbb29227c}" SpecialFunc="None">
    <Declaration><![CDATA[(*

