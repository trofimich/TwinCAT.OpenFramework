<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="DynamicQueueTest" Id="{14642f51-6650-4e18-929a-e30bf868bf01}" SpecialFunc="None">
    <Declaration><![CDATA[(*

