<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4026.18">
  <POU Name="RandomTest" Id="{2bc575a5-a2e8-41d3-a88b-91900261e812}" SpecialFunc="None">
    <Declaration><![CDATA[(*

